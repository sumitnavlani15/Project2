<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <h1 class="col-6 offset-3">SignUp on waunderLust</h1>
    <div class="col-6 offset-3">
     <form action="/signup" method="POST" class="needs-validation" novalidate>
       <div class="mb-3">
           <lable for="username" class="form-label">Username</lable>
           <input type="text" name = "username" placeholder="Enter title" class="form-control" id="username" required> 
           <div class="invalid-feedback">good</div>
        </div>
        <div class="mb-3">
           <lable for="email" class="form-label">Email</lable>
           <input type="email" name = "email" placeholder="Enter title" class="form-control" id="email" required> 
        </div>
        <div class="mb-3">
           <lable for="password" class="form-label">Password</lable>
           <input type="password" name = "password" placeholder="Enter title"  id = "password" class="form-control" id="email" required> 
        </div>
        <button class="btn btn-success">Sign Up</button>
        </form>    
    </div>
</div>